    {
      "cell_type": "markdown",
      "metadata": {
        "id": "3PhMXlWSxAXN"
      },
      "source": [
        "## Stage 4 — Prepare ML Features"
      ],
      "id": "3PhMXlWSxAXN"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "vZrxp7YbxAXO",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "9ba22873-fe4f-454f-c3ad-f3fbff73f4c7"
      },
      "source": [
        "df_ml = pd.get_dummies(df, columns=['risk_rating','category','card_type'], drop_first=True)\n",
        "df_ml = df_ml.drop(columns=['trans_id']).dropna()\n",
        "\n",
        "LABEL    = 'is_fraud'\n",
        "features = [c for c in df_ml.columns if c != LABEL]\n",
        "X = df_ml[features].astype(float)\n",
        "y = df_ml[LABEL].astype(int)\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.2, random_state=RANDOM_SEED, stratify=y\n",
        ")\n",
        "print(f\"Train: {len(X_train):,}   Test: {len(X_test):,}   Features: {len(features)}\")\n"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train: 400,000   Test: 100,000   Features: 27\n"
          ]
        }
      ],
      "id": "vZrxp7YbxAXO"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "z1TdGQ2jxAXO"
      },
      "source": [
        "## Stage 5 — Train Random Forest`class_weight='balanced'` adjusts for the ~2% fraud minority without resampling."
      ],
      "id": "z1TdGQ2jxAXO"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "E3L6uqG2xAXO",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "bdbd6f10-f8e4-4a08-bccc-6bdaca7a5222"
      },
      "source": [
        "clf = RandomForestClassifier(\n",
        "    n_estimators=200,\n",
        "    max_depth=12,\n",
        "    class_weight='balanced',\n",
        "    random_state=RANDOM_SEED,\n",
        "    n_jobs=-1\n",
        ")\n",
        "clf.fit(X_train, y_train)\n",
        "print(\"Training complete.\")\n"
      ],
